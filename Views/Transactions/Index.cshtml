@model IEnumerable<PaymentApp.Models.Transaction>
@{
    ViewData["Title"] = "Transactions";
    var currentPage = (int)ViewData["CurrentPage"]!;
    var totalPages = (int)ViewData["TotalPages"]!;
    var totalCount = (int)ViewData["TotalCount"]!;
    var acceptedCount = (int)ViewData["AcceptedCount"]!;
    var rejectedCount = (int)ViewData["RejectedCount"]!;
    var topReasons = (List<KeyValuePair<string, int>>)ViewData["TopReasons"]!;
}

<h2 class="text-2xl font-semibold mb-6">Transactions</h2>

<div class="grid grid-cols-3 gap-4 mb-6">
    <div class="bg-white rounded-lg shadow-sm border border-slate-200 p-4">
        <p class="text-sm text-slate-500">Total</p>
        <p class="text-2xl font-semibold text-slate-900 mt-1">@totalCount</p>
    </div>
    <div class="bg-white rounded-lg shadow-sm border border-slate-200 p-4">
        <p class="text-sm text-slate-500">Accepted</p>
        <p class="text-2xl font-semibold text-green-700 mt-1">@acceptedCount</p>
    </div>
    <div class="bg-white rounded-lg shadow-sm border border-slate-200 p-4">
        <p class="text-sm text-slate-500">Rejected</p>
        <p class="text-2xl font-semibold text-red-700 mt-1">@rejectedCount</p>
    </div>
</div>

@if (topReasons.Any())
{
    <div class="bg-white rounded-lg shadow-sm border border-slate-200 p-4 mb-6">
        <p class="text-sm font-medium text-slate-700 mb-3">Top Rejection Reasons</p>
        <ul class="space-y-2">
            @foreach (var reason in topReasons)
            {
                <li class="flex items-center justify-between text-sm">
                    <span class="text-slate-600">@reason.Key</span>
                    <span class="inline-flex px-2 py-0.5 rounded-full bg-slate-100 text-slate-700 text-xs font-mono">@reason.Value</span>
                </li>
            }
        </ul>
    </div>
}

@if (!Model.Any())
{
    <p class="text-slate-500">No transactions yet.</p>
}
else
{
    <div class="bg-white rounded-lg shadow-sm border border-slate-200 overflow-hidden">
        <table class="w-full text-sm">
            <thead class="bg-slate-100 text-slate-600 text-left">
                <tr>
                    <th class="px-4 py-3 font-medium">Date</th>
                    <th class="px-4 py-3 font-medium">Sender</th>
                    <th class="px-4 py-3 font-medium">Amount</th>
                    <th class="px-4 py-3 font-medium">IBAN</th>
                    <th class="px-4 py-3 font-medium">Result</th>
                    <th class="px-4 py-3 font-medium">Reference / Reason</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-200">
                @foreach (var t in Model)
                {
                    <tr class="hover:bg-slate-50">
                        <td class="px-4 py-3 text-slate-600 whitespace-nowrap">@t.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                        <td class="px-4 py-3">@t.SenderName</td>
                        <td class="px-4 py-3 font-mono">@t.Amount.ToString("0.00")</td>
                        <td class="px-4 py-3 font-mono text-xs">@t.EncryptedIban</td>
                        <td class="px-4 py-3">
                            @if (t.Result == "Accepted")
                            {
                                <span class="inline-flex px-2 py-0.5 rounded-full bg-green-100 text-green-800 text-xs font-medium">Accepted</span>
                            }
                            else
                            {
                                <span class="inline-flex px-2 py-0.5 rounded-full bg-red-100 text-red-800 text-xs font-medium">Rejected</span>
                            }
                        </td>
                        <td class="px-4 py-3 text-slate-600">@(t.TransactionReference ?? t.RejectionReason)</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="flex items-center justify-between mt-4">
        <p class="text-sm text-slate-600">Page @currentPage of @totalPages</p>
        <div class="flex gap-2">
            @if (currentPage > 1)
            {
                <a href="/transactions?page=@(currentPage - 1)"
                   class="px-3 py-1.5 rounded-md border border-slate-300 text-sm text-slate-700 hover:bg-slate-50 transition">
                    Previous
                </a>
            }
            else
            {
                <span class="px-3 py-1.5 rounded-md border border-slate-200 text-sm text-slate-400 cursor-not-allowed">Previous</span>
            }
            @if (currentPage < totalPages)
            {
                <a href="/transactions?page=@(currentPage + 1)"
                   class="px-3 py-1.5 rounded-md border border-slate-300 text-sm text-slate-700 hover:bg-slate-50 transition">
                    Next
                </a>
            }
            else
            {
                <span class="px-3 py-1.5 rounded-md border border-slate-200 text-sm text-slate-400 cursor-not-allowed">Next</span>
            }
        </div>
    </div>
}
