<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PaymentApp</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-50 text-slate-900 min-h-screen flex flex-col">
    <header class="bg-white border-b border-slate-200 shadow-sm">
        <nav class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
            <a href="/" class="text-xl font-semibold tracking-tight text-slate-900">
                PaymentApp
            </a>
            <ul class="flex items-center gap-6 text-sm font-medium">
                <li><a href="/" class="text-slate-600 hover:text-slate-900 transition">Home</a></li>
                <li><a href="/transactions" class="text-slate-600 hover:text-slate-900 transition">Transactions</a></li>
                <li><a href="/blocked" class="text-slate-600 hover:text-slate-900 transition">Blocked</a></li>
            </ul>
        </nav>
    </header>

    <main class="flex-1 max-w-5xl w-full mx-auto px-6 py-8">
        @RenderBody()
    </main>

    <footer class="border-t border-slate-200 py-4 text-center text-sm text-slate-500">
        &copy; 2026 PaymentApp
    </footer>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
