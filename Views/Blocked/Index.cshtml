@model IEnumerable<PaymentApp.Models.BlacklistedPerson>
@{
    ViewData["Title"] = "Blocked";
}

<h2 class="text-2xl font-semibold mb-6">Blocked Senders</h2>

@if (!Model.Any())
{
    <p class="text-slate-500">No blocked senders.</p>
}
else
{
    <div class="bg-white rounded-lg shadow-sm border border-slate-200 overflow-hidden max-w-md">
        <table class="w-full text-sm">
            <thead class="bg-slate-100 text-slate-600 text-left">
                <tr>
                    <th class="px-4 py-3 font-medium">Name</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-200">
                @foreach (var person in Model)
                {
                    <tr class="hover:bg-slate-50">
                        <td class="px-4 py-3">@person.Name</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
